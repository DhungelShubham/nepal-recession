# Python cache
__pycache__/
*.pyc
*.pyo

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Virtual environments
env/
venv/
*.env

# Conda environments (never commit these)
# (your env stays local only)

# Data (optional but recommended for ML projects)
data/raw/
data/processed/

# Models (optional if large)
models/*.pkl
models/*.joblib

# OS files
.DS_Store

# Logs
*.log


